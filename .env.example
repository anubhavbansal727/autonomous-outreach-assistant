# ============================================================
# Mini CRM AI Crew — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# LLM
# ------------------------------------------------------------

# OpenAI API key — used by all LangGraph agent nodes (GPT-4o)
# Get it at: https://platform.openai.com → API Keys
OPENAI_API_KEY=


# ------------------------------------------------------------
# Search
# ------------------------------------------------------------

# Serper web search API key — used by the web_search @tool in the Research Agent
# Free tier: 100 searches/month. Use MOCK_MODE=true during development to preserve quota.
# Get it at: https://serper.dev → Dashboard → API Key
SERPER_API_KEY=


# ------------------------------------------------------------
# Email Delivery
# ------------------------------------------------------------

# Resend API key — required for the Approve & Send flow
# Domain must be verified in the Resend dashboard before sends will work.
# Get it at: https://resend.com → API Keys
RESEND_API_KEY=


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# PostgreSQL async connection string
# Local (Docker): postgresql+asyncpg://postgres:postgres@localhost:5432/mini_crm
# Railway: copy from Railway Postgres plugin → Connect → asyncpg URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mini_crm


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

# Redis connection string — used by ARQ job queue and rate limiter
# Local (Docker): redis://localhost:6379
# Railway: copy from Railway Redis plugin → Connect
REDIS_URL=redis://localhost:6379


# ------------------------------------------------------------
# Auth — JWT
# ------------------------------------------------------------

# Secret key used to sign all JWTs (access + refresh tokens)
# Generate with: openssl rand -hex 32
# WARNING: Rotating this key logs out every active user immediately.
JWT_SECRET_KEY=

# JWT signing algorithm — default is HS256, no need to change
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 30)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ------------------------------------------------------------
# Observability — LangSmith (optional)
# ------------------------------------------------------------

# Set to "true" to enable LangSmith tracing for all LangGraph runs
# Leave unset (or "false") to disable — no traces will be sent
LANGCHAIN_TRACING_V2=false

# LangSmith API key — only required when LANGCHAIN_TRACING_V2=true
# Get it at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=

# LangSmith project name — traces will appear under this project in the dashboard
LANGCHAIN_PROJECT=mini-crm-ai-crew


# ------------------------------------------------------------
# Development / Demo
# ------------------------------------------------------------

# Set to "true" to bypass all LLM and external API calls
# ARQ jobs will load fixture JSON from backend/fixtures/ instead
# Step updates still fire with 2-second delays to simulate real timing
# Use this during frontend development and demos
MOCK_MODE=false


# ------------------------------------------------------------
# CORS — Allowed Origins
# ------------------------------------------------------------

# Comma-separated list of origins the API will accept cross-origin requests from.
# Local dev default is already set in code; only override this in production.
# Set this in your Railway backend service env vars:
#   CORS_ORIGINS=https://your-project.vercel.app
CORS_ORIGINS=http://localhost:5173


# ------------------------------------------------------------
# Frontend (Vite)
# ------------------------------------------------------------

# NOT used at runtime — the frontend calls /api/* which Vercel proxies to Railway.
# Kept here for reference / local-override documentation only.
# VITE_API_BASE_URL=http://localhost:8000


# ------------------------------------------------------------
# Docker (local Postgres container only)
# Used by docker-compose.yml to initialise the Postgres service.
# Not read by the application — DATABASE_URL above is what the app uses.
# ------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mini_crm
